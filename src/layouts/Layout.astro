---
import '../styles/global.css';
import treeSvg from '../assets/tree.svg?raw';
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Astro Basics</title>
	</head>
	<body class="app-loading-active">
		<div
			id="app-loading"
			class="app-loading"
			role="status"
			aria-live="polite"
			aria-busy="true"
		>
			<div id="app-loading-tree" class="app-loading__tree" set:html={treeSvg} aria-hidden="true" />
			<p class="app-loading__text">Loading…</p>
		</div>
		<slot />
		<script>
			import '../scripts/loadingScreen.ts';
		</script>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		/* Let the document grow past the viewport so ScrollTrigger pin + scrub can scroll */
		min-height: 100%;
	}
</style>
